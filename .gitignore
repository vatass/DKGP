# Allow only Python, Markdown, and Shell script files
# Block everything else by default

# Allow specific file types
!*.py
!*.md
!*.sh
!*.yml
!*.yaml
!*.json
!*.txt
!*.gitignore

# Block all other file types
*
!*/

# Re-allow the specific file types we want
!*.py
!*.md
!*.sh
!*.yml
!*.yaml
!*.json
!*.txt
!*.gitignore

# Block specific directories that should never be tracked
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.ipynb_checkpoints/
venv/
dkgp-venv/
env/
ENV/
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
*.tmp
*.temp
*~

# Block large data and model files specifically
data/
models/
models_*/
logs_*/
evaluation_results_*/
inference_results_*/
future_inference_results/
population_demographics_results/
trajectory_plots/
hippocampus_analysis/

# Remove specific result directories
population_demographics_results/
evaluation_results_hmuse0/

# Output directory for inference results
output/

# Plot directories (keep locally but don't track in Git)
trajectory_plots/
validation_plots/
single_subject_plots/

# Additional result and log directories
future_inference_results/
evaluation_results_*/
inference_results*/
logs_*/
population_demographics_results/

# Unused shell scripts (kept locally but not tracked in Git)
preprocess_data.sh
setup_environment.sh
run_training_all_rois.sh
run_training_cognitive_scores.sh
run_training_spare_scores.sh
run_inference_backup.sh
run_complete_evaluation.sh

# Python cache
__pycache__/

# Temporary files
*.tmp
*.temp
*~
